# Copy this file to .env and fill in real values before running the dev server or building.
# The .env file is git-ignored; never commit it.

# Gaode Maps (amap) web API key - obtain from https://console.amap.com/
VITE_AMAP_KEY=your-gaode-web-api-key-here

# Gaode Maps JS security code (only required when security verification is enabled in the console)
VITE_AMAP_SECURITY_CODE=your-gaode-security-js-code-here
